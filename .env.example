# Copy to .env and fill in.

# Shared secret used to sign/verify the RPC bearer token. Any long random string, e.g.
#   openssl rand -hex 32
# The SAME value must be set on the Worker:  npx wrangler secret put REPRO_SECRET
REPRO_SECRET=

# Your deployed Worker URL (printed by `npx wrangler deploy`).
WORKER_URL=https://sandbox-sdk-issue-794.<your-subdomain>.workers.dev
